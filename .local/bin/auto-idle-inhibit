#!/bin/bash

inhibit_pid=""

while true; do
    # Check if any audio sink is actually playing (RUNNING state)
    audio_playing=$(pactl list sink-inputs | grep -c "State: RUNNING")
    
    # Check for fullscreen windows (common when watching videos)
    fullscreen=$(hyprctl activewindow -j | jq -r '.fullscreen')
    
    should_inhibit=false
    
    if [ "$audio_playing" -gt 0 ]; then
        should_inhibit=true
    fi
    
    # Also inhibit if window is fullscreen
    if [ "$fullscreen" != "0" ]; then
        should_inhibit=true
    fi
    
    if [ "$should_inhibit" = true ]; then
        if [ -z "$inhibit_pid" ] || ! kill -0 "$inhibit_pid" 2>/dev/null; then
            systemd-inhibit --what=idle --who="auto-inhibit" --why="Media/Fullscreen" sleep infinity &
            inhibit_pid=$!
        fi
    else
        if [ -n "$inhibit_pid" ] && kill -0 "$inhibit_pid" 2>/dev/null; then
            kill "$inhibit_pid" 2>/dev/null
            inhibit_pid=""
        fi
    fi
    
    sleep 3
done
